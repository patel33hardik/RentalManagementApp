<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Rental Manager</title>
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>

<%- include('_sidebar', { activePage: 'dashboard' }) %>

<div class="main-wrapper" id="mainWrapper">
  <%- include('_topbar', { title: 'Dashboard' }) %>

  <main class="page-content">

    <!-- Summary Cards -->
    <div class="row g-4 mb-4">
      <div class="col-xl-3 col-md-6">
        <div class="stat-card stat-card--income">
          <div class="stat-card__icon"><i class="bi bi-cash-stack"></i></div>
          <div class="stat-card__body">
            <div class="stat-card__label">Total Income</div>
            <div class="stat-card__value" id="totalIncome">—</div>
          </div>
        </div>
      </div>
      <div class="col-xl-3 col-md-6">
        <div class="stat-card stat-card--expense">
          <div class="stat-card__icon"><i class="bi bi-arrow-down-circle"></i></div>
          <div class="stat-card__body">
            <div class="stat-card__label">Total Expenses</div>
            <div class="stat-card__value" id="totalExpenses">—</div>
          </div>
        </div>
      </div>
      <div class="col-xl-3 col-md-6">
        <div class="stat-card stat-card--profit">
          <div class="stat-card__icon"><i class="bi bi-graph-up-arrow"></i></div>
          <div class="stat-card__body">
            <div class="stat-card__label">Net Profit</div>
            <div class="stat-card__value" id="netProfit">—</div>
          </div>
        </div>
      </div>
      <div class="col-xl-3 col-md-6">
        <div class="stat-card stat-card--bond">
          <div class="stat-card__icon"><i class="bi bi-safe2"></i></div>
          <div class="stat-card__body">
            <div class="stat-card__label">Bond Held</div>
            <div class="stat-card__value" id="bondHeld">—</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Active Tenants -->
    <div class="panel mb-4">
      <div class="panel__header">
        <h2 class="panel__title"><i class="bi bi-people me-2"></i>Active Tenants</h2>
        <a href="/add-tenant" class="btn btn-sm btn-primary">
          <i class="bi bi-person-plus me-1"></i>Add Tenant
        </a>
      </div>
      <div class="panel__body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0" id="activeTable">
            <thead>
              <tr>
                <th>Room</th>
                <th>Tenant</th>
                <th>Move-in</th>
                <th>Weekly Rent</th>
                <th>Bond</th>
                <th>Pending Weeks</th>
                <th>Total Received</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <tr><td colspan="8" class="text-center py-3 text-muted">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Moved Out Tenants -->
    <div class="panel">
      <div class="panel__header">
        <h2 class="panel__title"><i class="bi bi-box-arrow-right me-2"></i>Moved Out</h2>
      </div>
      <div class="panel__body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0" id="movedOutTable">
            <thead>
              <tr>
                <th>Room</th>
                <th>Tenant</th>
                <th>Move-in</th>
                <th>Move-out</th>
                <th>Weekly Rent</th>
                <th>Bond</th>
                <th>Bond Refund Date</th>
                <th>Total Received</th>
              </tr>
            </thead>
            <tbody>
              <tr><td colspan="8" class="text-center py-3 text-muted">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </main>
</div>

<%- include('_scripts') %>
<script>
$(function() {
  loadSummary();
  loadActiveTenants();
  loadMovedOut();
});

function loadSummary() {
  $.getJSON('/api/dashboard', function(res) {
    if (!res.success) return;
    const d = res.data;
    $('#totalIncome').text(fmt(d.total_income));
    $('#totalExpenses').text(fmt(d.total_expenses));
    $('#netProfit').text(fmt(d.net_profit)).toggleClass('text-danger', d.net_profit < 0);
    $('#bondHeld').text(fmt(d.bond_held));
  });
}

function loadActiveTenants() {
  $.getJSON('/api/tenants?status=Active', function(res) {
    const tbody = $('#activeTable tbody');
    tbody.empty();
    if (!res.success || res.data.length === 0) {
      tbody.html('<tr><td colspan="8" class="text-center text-muted py-3">No active tenants</td></tr>');
      return;
    }
    res.data.forEach(function(t) {
      const pendingClass = t.pending_weeks > 0 ? 'text-warning fw-semibold' : 'text-muted';
      tbody.append(`
        <tr>
          <td><span class="room-badge">Room ${t.room_number}</span></td>
          <td class="fw-semibold">${t.name}</td>
          <td class="text-muted small">${fmtDate(t.move_in)}</td>
          <td>${fmt(t.weekly_rent)}<span class="text-muted">/wk</span></td>
          <td>${fmt(t.bond)}</td>
          <td><span class="${pendingClass}">${t.pending_weeks}</span></td>
          <td class="text-success fw-semibold">${fmt(t.total_received)}</td>
          <td class="text-end">
            <a href="/tenant/${t.id}" class="btn btn-xs btn-outline-primary">
              <i class="bi bi-journal-text me-1"></i>Ledger
            </a>
          </td>
        </tr>
      `);
    });
  });
}

function loadMovedOut() {
  $.getJSON('/api/tenants?status=Inactive', function(res) {
    const tbody = $('#movedOutTable tbody');
    tbody.empty();
    if (!res.success || res.data.length === 0) {
      tbody.html('<tr><td colspan="8" class="text-center text-muted py-3">No previous tenants</td></tr>');
      return;
    }
    const sorted = res.data.slice().sort(function(a, b) {
      return (b.move_out || '').localeCompare(a.move_out || '');
    });
    sorted.forEach(function(t) {
      const refundLabel = t.bond_refund_date
        ? `<span class="status-badge badge-paid">${fmtDate(t.bond_refund_date)}</span>`
        : `<span class="text-muted">—</span>`;
      tbody.append(`
        <tr>
          <td><span class="room-badge">Room ${t.room_number}</span></td>
          <td class="fw-semibold">${t.name}</td>
          <td class="text-muted small">${fmtDate(t.move_in)}</td>
          <td class="text-muted small">${fmtDate(t.move_out)}</td>
          <td>${fmt(t.weekly_rent)}<span class="text-muted">/wk</span></td>
          <td>${fmt(t.bond)}</td>
          <td>${refundLabel}</td>
          <td class="text-success fw-semibold">${fmt(t.total_received)}</td>
        </tr>
      `);
    });
  });
}
</script>
</body>
</html>
