<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rooms — Rental Manager</title>
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>

<%- include('_sidebar', { activePage: 'rooms' }) %>

<div class="main-wrapper" id="mainWrapper">
  <%- include('_topbar', { title: 'Rooms Overview' }) %>

  <main class="page-content">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <p class="text-muted mb-0">Manage your 4 rooms and their current tenants.</p>
      <a href="/add-tenant" class="btn btn-primary">
        <i class="bi bi-person-plus me-2"></i>Add New Tenant
      </a>
    </div>

    <div class="row g-4" id="roomCards">
      <!-- Populated by JS -->
      <% for(let i = 0; i < 4; i++) { %>
      <div class="col-xl-6">
        <div class="panel loading-shimmer" style="min-height:200px;"></div>
      </div>
      <% } %>
    </div>

  </main>
</div>

<%- include('_scripts') %>
<script>
$(function() {
  $.getJSON('/api/rooms', function(res) {
    if (!res.success) return;
    const container = $('#roomCards');
    container.empty();

    res.data.forEach(function(room) {
      const occupied = !!room.tenant_name;
      const statusClass = occupied ? 'occupied' : 'vacant';
      const pct = room.total_received && room.weekly_rent
        ? Math.min(100, Math.round((room.total_received / (room.weekly_rent * 20)) * 100))
        : 0;

      container.append(`
        <div class="col-xl-6">
          <div class="room-card room-card--${statusClass}">
            <div class="room-card__header">
              <div>
                <div class="room-card__number">Room ${room.room_number}</div>
                <div class="room-card__desc">${room.description || ''}</div>
              </div>
              <span class="status-badge ${occupied ? 'badge-paid' : 'badge-vacant'}">
                ${occupied ? 'Occupied' : 'Vacant'}
              </span>
            </div>

            <div class="room-card__body">
              ${occupied ? `
                <div class="room-card__tenant">
                  <div class="tenant-avatar">${room.tenant_name.charAt(0).toUpperCase()}</div>
                  <div class="tenant-info">
                    <div class="tenant-name">${room.tenant_name}</div>
                    <div class="tenant-meta">Since ${fmtDate(room.move_in)}</div>
                  </div>
                </div>

                <div class="room-card__stats">
                  <div class="stat-item">
                    <div class="stat-item__label">Weekly Rent</div>
                    <div class="stat-item__value">${fmt(room.weekly_rent)}</div>
                  </div>
                  <div class="stat-item">
                    <div class="stat-item__label">Total Received</div>
                    <div class="stat-item__value">${fmt(room.total_received)}</div>
                  </div>
                  <div class="stat-item">
                    <div class="stat-item__label">Bond</div>
                    <div class="stat-item__value">${fmt(room.bond)}</div>
                  </div>
                  <div class="stat-item">
                    <div class="stat-item__label">Pending Weeks</div>
                    <div class="stat-item__value ${room.pending_weeks > 0 ? 'text-warning' : ''}">${room.pending_weeks}</div>
                  </div>
                </div>

                <div class="room-card__actions">
                  <a href="/tenant/${room.tenant_id}" class="btn btn-sm btn-primary">
                    <i class="bi bi-journal-text me-1"></i>View Ledger
                  </a>
                  <button class="btn btn-sm btn-outline-secondary" onclick="editTenant(${room.tenant_id})">
                    <i class="bi bi-pencil me-1"></i>Edit
                  </button>
                </div>
              ` : `
                <div class="text-center py-3">
                  <i class="bi bi-door-open display-6 text-muted"></i>
                  <p class="text-muted mt-2">This room is vacant</p>
                  <a href="/add-tenant?room=${room.room_number}" class="btn btn-sm btn-primary mt-1">
                    <i class="bi bi-person-plus me-1"></i>Add Tenant
                  </a>
                </div>
              `}
            </div>
          </div>
        </div>
      `);
    });
  });
});

function editTenant(id) {
  window.location.href = `/add-tenant?edit=${id}`;
}
</script>
</body>
</html>
