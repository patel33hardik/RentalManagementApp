<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rooms — Rental Manager</title>
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>

<%- include('_sidebar', { activePage: 'rooms' }) %>

<div class="main-wrapper" id="mainWrapper">
  <%- include('_topbar', { title: 'Rooms Overview' }) %>

  <main class="page-content">

    <!-- Header: swapped in by JS based on property filter -->
    <div class="d-flex justify-content-between align-items-center mb-4" id="pageHeader">
      <div>
        <p class="text-muted mb-0" id="pageSubtitle">Loading…</p>
      </div>
      <div class="d-flex gap-2" id="headerActions">
        <!-- populated by JS -->
      </div>
    </div>

    <div id="roomCards">
      <div class="row g-4">
        <% for(let i = 0; i < 4; i++) { %>
        <div class="col-xl-6">
          <div class="panel loading-shimmer" style="min-height:200px;"></div>
        </div>
        <% } %>
      </div>
    </div>

  </main>
</div>

<!-- Delete Room Modal -->
<div class="modal fade" id="deleteRoomModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger"><i class="bi bi-trash me-2"></i>Delete Room</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="mb-1">Delete <strong id="deleteRoomLabel"></strong>?</p>
        <p class="text-muted small mb-0">This cannot be undone. All past tenant history for this room will also be removed.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-danger btn-sm" id="deleteRoomConfirmBtn">
          <i class="bi bi-trash me-1"></i>Delete
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Add Room Modal -->
<div class="modal fade" id="addRoomModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Add Room</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="addRoomPropertyId">
        <div class="mb-3">
          <label class="form-label">Room Number <span class="text-danger">*</span></label>
          <input type="number" class="form-control" id="addRoomNumber" min="1" placeholder="e.g. 5">
        </div>
        <div class="mb-0">
          <label class="form-label">Description</label>
          <input type="text" class="form-control" id="addRoomDesc" placeholder="e.g. Master Bedroom">
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary btn-sm" id="addRoomSaveBtn">
          <i class="bi bi-plus me-1"></i>Add Room
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('_scripts') %>
<script>
$(function() {
  const prop = requireProp();
  if (!prop) return;

  // URL param overrides stored property (used by "Filter" links in all-props view)
  const params     = new URLSearchParams(window.location.search);
  const filterProp = params.get('property') || prop.id;

  loadSingleProperty(filterProp);

  // ── Single property view ──────────────────────────────────────────────────────
  function loadSingleProperty(propId) {
    $.when(
      $.getJSON(`/api/properties/${propId}`),
      $.getJSON(`/api/rooms?property_id=${propId}`)
    ).done(function(propRes, roomsRes) {
      const prop  = propRes[0].data;
      const rooms = roomsRes[0].data;

      document.title = prop.name + ' — Rooms';
      $('#pageSubtitle').text(`${rooms.length} room${rooms.length !== 1 ? 's' : ''} · ${prop.type === 'rooming' ? 'Rooming' : 'Whole Property'}`);

      // Header actions — vary by property type
      let actions = `<a href="/properties" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>All Properties
      </a>`;
      if (prop.type === 'rooming') {
        actions += `<button class="btn btn-sm btn-primary" onclick="openAddRoom(${propId})">
          <i class="bi bi-plus me-1"></i>Add Room
        </button>`;
      } else {
        // Whole property: Add Tenant only when currently vacant
        const isOccupied = rooms.length > 0 && !!rooms[0].tenant_name;
        if (!isOccupied) {
          actions += `<a href="/add-tenant?property=${propId}" class="btn btn-sm btn-primary">
            <i class="bi bi-person-plus me-2"></i>Add Tenant
          </a>`;
        }
      }
      $('#headerActions').html(actions);

      renderRoomCards($('#roomCards'), rooms, propId, prop.type);
    });
  }

  // ── All properties view ───────────────────────────────────────────────────────
  function loadAllProperties() {
    $.when(
      $.getJSON('/api/properties'),
      $.getJSON('/api/rooms')
    ).done(function(propsRes, roomsRes) {
      const props    = propsRes[0].data;
      const allRooms = roomsRes[0].data;

      const total = allRooms.length;
      $('#pageSubtitle').text(`${total} room${total !== 1 ? 's' : ''} across ${props.length} propert${props.length !== 1 ? 'ies' : 'y'}`);
      $('#headerActions').html(`<a href="/add-tenant" class="btn btn-sm btn-primary">
        <i class="bi bi-person-plus me-2"></i>Add Tenant
      </a>`);

      const container = $('#roomCards');
      container.empty();

      if (props.length === 0) {
        container.html(`<div class="text-center py-5">
          <i class="bi bi-building display-4 text-muted"></i>
          <p class="text-muted mt-3">No properties yet.
            <a href="/add-property">Add your first property</a> to get started.
          </p>
        </div>`);
        return;
      }

      props.forEach(function(prop) {
        const propRooms = allRooms.filter(r => r.property_id == prop.id);
        if (propRooms.length === 0) return;

        // Property group header
        const groupId = `group_${prop.id}`;
        const typeIcon = prop.type === 'rooming' ? 'bi-door-open' : 'bi-house-door';
        container.append(`
          <div class="col-12 mt-2">
            <div class="d-flex align-items-center gap-2 mb-1">
              <i class="bi ${typeIcon} text-primary"></i>
              <span class="fw-semibold" style="font-size:14px">${prop.name}</span>
              ${prop.address ? `<span class="text-muted small">· ${prop.address}</span>` : ''}
              <a href="/rooms?property=${prop.id}" class="btn btn-xs btn-outline-secondary ms-auto">
                <i class="bi bi-filter me-1"></i>Filter
              </a>
            </div>
          </div>
          <div class="col-12">
            <div class="row g-4" id="${groupId}"></div>
          </div>
        `);
        renderRoomCards($(`#${groupId}`), propRooms, prop.id, prop.type);
      });
    });
  }

  // ── Shared room card renderer ─────────────────────────────────────────────────
  function renderRoomCards(container, rooms, propId, propType) {
    container.empty();

    if (rooms.length === 0) {
      container.html(`<div class="col-12 text-center py-4 text-muted">
        <i class="bi bi-door-open display-5"></i>
        <p class="mt-2">No rooms yet. Use Add Room to create one.</p>
      </div>`);
      return;
    }

    rooms.forEach(function(room) {
      const occupied    = !!room.tenant_name;
      const statusClass = occupied ? 'occupied' : 'vacant';

      container.append(`
        <div class="col-xl-6">
          <div class="room-card room-card--${statusClass}">
            <div class="room-card__header">
              <div>
                <div class="room-card__number">Room ${room.room_number}</div>
                <div class="room-card__desc">${room.description || ''}</div>
              </div>
              <span class="status-badge ${occupied ? 'badge-paid' : 'badge-vacant'}">
                ${occupied ? 'Occupied' : 'Vacant'}
              </span>
            </div>

            <div class="room-card__body">
              ${occupied ? `
                <div class="room-card__tenant">
                  <div class="tenant-avatar">${room.tenant_name.charAt(0).toUpperCase()}</div>
                  <div class="tenant-info">
                    <div class="tenant-name">${room.tenant_name}</div>
                    <div class="tenant-meta">Since ${fmtDate(room.move_in)}</div>
                  </div>
                </div>
                <div class="room-card__stats">
                  <div class="stat-item">
                    <div class="stat-item__label">Weekly Rent</div>
                    <div class="stat-item__value">${fmt(room.weekly_rent)}</div>
                  </div>
                  <div class="stat-item">
                    <div class="stat-item__label">Total Received</div>
                    <div class="stat-item__value">${fmt(room.total_received)}</div>
                  </div>
                  <div class="stat-item">
                    <div class="stat-item__label">Bond</div>
                    <div class="stat-item__value">${fmt(room.bond)}</div>
                  </div>
                  <div class="stat-item">
                    <div class="stat-item__label">Pending Weeks</div>
                    <div class="stat-item__value ${room.pending_weeks > 0 ? 'text-warning' : ''}">${room.pending_weeks}</div>
                  </div>
                </div>
                <div class="room-card__actions">
                  <a href="/tenant/${room.tenant_id}" class="btn btn-sm btn-primary">
                    <i class="bi bi-journal-text me-1"></i>View Ledger
                  </a>
                  <button class="btn btn-sm btn-outline-secondary" onclick="editTenant(${room.tenant_id})">
                    <i class="bi bi-pencil me-1"></i>Edit
                  </button>
                  <button class="btn btn-sm btn-outline-danger" disabled
                          title="Cannot delete — room has an active tenant">
                    <i class="bi bi-trash"></i>
                  </button>
                </div>
              ` : `
                <div class="text-center py-3">
                  <i class="bi bi-door-open display-6 text-muted"></i>
                  <p class="text-muted mt-2">This room is vacant</p>
                  <div class="d-flex gap-2 justify-content-center mt-1">
                    ${propType !== 'whole' ? `
                      <a href="/add-tenant?room=${room.id}&property=${propId}" class="btn btn-sm btn-primary">
                        <i class="bi bi-person-plus me-1"></i>Add Tenant
                      </a>
                    ` : ''}
                    <button class="btn btn-sm btn-outline-danger"
                            onclick="openDeleteRoom(${room.id}, ${propId}, 'Room ${room.room_number}${room.description ? ' — ' + room.description : ''}')">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </div>
              `}
            </div>
          </div>
        </div>
      `);
    });
  }

  // ── Delete Room modal ─────────────────────────────────────────────────────────
  $('#deleteRoomConfirmBtn').on('click', function() {
    const roomId = $('#deleteRoomModal').data('roomId');
    const propId = $('#deleteRoomModal').data('propId');
    if (!roomId) return;
    $.ajax({
      url: `/api/rooms/${roomId}`, method: 'DELETE',
      success: function(res) {
        bootstrap.Modal.getInstance(document.getElementById('deleteRoomModal')).hide();
        if (res.success) {
          showToast('Room deleted', 'success');
          loadSingleProperty(propId);
        } else {
          showToast(res.error || 'Error deleting room', 'error');
        }
      }
    });
  });

  // ── Add Room modal ────────────────────────────────────────────────────────────
  $('#addRoomSaveBtn').on('click', function() {
    const propId  = $('#addRoomPropertyId').val();
    const number  = $('#addRoomNumber').val();
    const desc    = $('#addRoomDesc').val().trim();
    if (!number) { showToast('Room number is required', 'error'); return; }

    $.ajax({
      url: '/api/rooms',
      method: 'POST',
      contentType: 'application/json',
      data: JSON.stringify({ property_id: propId, room_number: number, description: desc }),
      success: function(res) {
        if (res.success) {
          bootstrap.Modal.getInstance(document.getElementById('addRoomModal')).hide();
          showToast('Room added', 'success');
          loadSingleProperty(propId);
        } else {
          showToast(res.error || 'Error', 'error');
        }
      }
    });
  });
});

function openDeleteRoom(roomId, propId, label) {
  $('#deleteRoomLabel').text(label);
  $('#deleteRoomModal').data('roomId', roomId).data('propId', propId);
  new bootstrap.Modal(document.getElementById('deleteRoomModal')).show();
}

function openAddRoom(propId) {
  $('#addRoomPropertyId').val(propId);
  $('#addRoomNumber').val('');
  $('#addRoomDesc').val('');
  new bootstrap.Modal(document.getElementById('addRoomModal')).show();
}

function editTenant(id) {
  window.location.href = `/add-tenant?edit=${id}`;
}
</script>
</body>
</html>
