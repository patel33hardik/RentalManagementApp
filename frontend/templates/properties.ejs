<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Properties — Rental Manager</title>
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>

<%- include('_sidebar', { activePage: 'properties' }) %>

<div class="main-wrapper" id="mainWrapper">
  <%- include('_topbar', { title: 'Properties' }) %>

  <main class="page-content">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <p class="text-muted mb-0" id="propSubtitle">Select a property to manage.</p>
      </div>
      <a href="/add-property" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Add Property
      </a>
    </div>

    <div class="row g-4" id="propertyCards">
      <% for(let i = 0; i < 2; i++) { %>
      <div class="col-xl-6">
        <div class="panel loading-shimmer" style="min-height:220px;"></div>
      </div>
      <% } %>
    </div>

  </main>
</div>

<!-- Edit Property Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Property</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="editPropId">
        <div class="mb-3">
          <label class="form-label">Property Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="editPropName">
        </div>
        <div class="mb-3">
          <label class="form-label">Address</label>
          <input type="text" class="form-control" id="editPropAddress" placeholder="Full address">
        </div>
        <div class="mb-0">
          <label class="form-label">Notes</label>
          <textarea class="form-control" id="editPropNotes" rows="2"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" id="editSaveBtn"><i class="bi bi-save me-1"></i>Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger"><i class="bi bi-trash me-2"></i>Delete Property</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="mb-1">Delete <strong id="deletePropName"></strong>?</p>
        <p class="text-muted small mb-0">All rooms, tenants and ledger records will be permanently removed.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-danger" id="deleteConfirmBtn"><i class="bi bi-trash me-1"></i>Delete</button>
      </div>
    </div>
  </div>
</div>

<%- include('_scripts') %>
<script>
let deletePropId = null;

function openProp(id, name, type, address) {
  setProp({ id, name, type, address });
  window.location.href = '/dashboard';
}

function escHtml(str) {
  return String(str).replace(/\\/g,'\\\\').replace(/'/g,"\\'");
}

function loadProperties() {
  $.getJSON('/api/properties', function(res) {
    if (!res.success) return;
    const data    = res.data;
    const current = getProp();

    $('#propSubtitle').text(
      data.length === 0 ? 'No properties yet. Add one to get started.' :
      data.length === 1 ? '1 property — click Open to manage it.' :
      `${data.length} properties — select one to manage.`
    );

    // Auto-select if only one property and none stored
    if (data.length === 1 && !current) {
      const p = data[0];
      setProp({ id: p.id, name: p.name, type: p.type, address: p.address || '' });
      window.location.href = '/dashboard';
      return;
    }

    const container = $('#propertyCards');
    container.empty();

    if (data.length === 0) {
      container.html(`
        <div class="col-12 text-center py-5">
          <i class="bi bi-building display-4 text-muted"></i>
          <p class="text-muted mt-3 mb-4">No properties yet.</p>
          <a href="/add-property" class="btn btn-primary"><i class="bi bi-plus-circle me-2"></i>Add Property</a>
        </div>`);
      return;
    }

    data.forEach(function(p) {
      const isRooming  = p.type === 'rooming';
      const typeIcon   = isRooming ? 'bi-door-open' : 'bi-house-door';
      const typeLabel  = isRooming ? 'Rooming' : 'Whole Property';
      const isActive   = current && current.id === p.id;

      const occupancy = isRooming
        ? `${p.active_tenants} / ${p.room_count} rooms occupied`
        : (p.active_tenants > 0 ? 'Occupied' : 'Vacant');
      const occupancyClass = p.active_tenants > 0 ? 'text-success' : 'text-muted';

      const pendingBadge = p.pending_weeks > 0
        ? `<span class="badge bg-warning text-dark ms-2">${p.pending_weeks} pending</span>`
        : '';

      container.append(`
        <div class="col-xl-6">
          <div class="property-card ${isActive ? 'property-card--active' : ''}"
               style="cursor:pointer;" onclick="openProp(${p.id},'${escHtml(p.name)}','${p.type}','${escHtml(p.address||'')}')">
            <div class="property-card__header">
              <div class="property-card__icon">
                <i class="bi ${typeIcon}"></i>
              </div>
              <div class="property-card__info">
                <div class="property-card__name">${p.name}
                  ${isActive ? '<span class="badge bg-primary ms-2" style="font-size:10px;">Active</span>' : ''}
                </div>
                <div class="property-card__address">${p.address || '<span class="fst-italic">No address</span>'}</div>
              </div>
              <div class="d-flex flex-column align-items-end gap-1">
                <span class="property-type-badge property-type-badge--${p.type}">${typeLabel}</span>
                ${pendingBadge}
              </div>
            </div>

            <div class="property-card__body">
              <div class="property-card__stats">
                <div class="stat-item">
                  <div class="stat-item__label">Occupancy</div>
                  <div class="stat-item__value ${occupancyClass}" style="font-size:14px;">${occupancy}</div>
                </div>
                <div class="stat-item">
                  <div class="stat-item__label">Total Received</div>
                  <div class="stat-item__value">${fmt(p.total_received)}</div>
                </div>
              </div>

              <div class="property-card__actions" onclick="event.stopPropagation();">
                <button class="btn btn-primary btn-sm flex-grow-1"
                        onclick="openProp(${p.id},'${escHtml(p.name)}','${p.type}','${escHtml(p.address||'')}')">
                  <i class="bi bi-box-arrow-in-right me-1"></i>Open
                </button>
                <button class="btn btn-sm btn-outline-secondary"
                        onclick="openEdit(${p.id},'${escHtml(p.name)}','${escHtml(p.address||'')}','${escHtml(p.notes||'')}')">
                  <i class="bi bi-pencil"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger"
                        onclick="openDelete(${p.id},'${escHtml(p.name)}')">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      `);
    });
  });
}

function openEdit(id, name, address, notes) {
  $('#editPropId').val(id);
  $('#editPropName').val(name);
  $('#editPropAddress').val(address);
  $('#editPropNotes').val(notes);
  new bootstrap.Modal(document.getElementById('editModal')).show();
}

function openDelete(id, name) {
  deletePropId = id;
  $('#deletePropName').text(name);
  new bootstrap.Modal(document.getElementById('deleteModal')).show();
}

$(function() {
  loadProperties();

  $('#editSaveBtn').on('click', function() {
    const id   = $('#editPropId').val();
    const name = $('#editPropName').val().trim();
    if (!name) { showToast('Name is required', 'error'); return; }
    $.ajax({
      url: `/api/properties/${id}`, method: 'PUT', contentType: 'application/json',
      data: JSON.stringify({ name, address: $('#editPropAddress').val().trim(), notes: $('#editPropNotes').val().trim() }),
      success: function(res) {
        if (res.success) {
          // Update localStorage if this is the active property
          const cur = getProp();
          if (cur && cur.id == id) setProp({ ...cur, name, address: $('#editPropAddress').val().trim() });
          bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
          showToast('Property updated', 'success');
          loadProperties();
        } else { showToast(res.error || 'Error', 'error'); }
      }
    });
  });

  $('#deleteConfirmBtn').on('click', function() {
    if (!deletePropId) return;
    $.ajax({
      url: `/api/properties/${deletePropId}`, method: 'DELETE',
      success: function(res) {
        if (res.success) {
          // Clear localStorage if the deleted property was active
          const cur = getProp();
          if (cur && cur.id == deletePropId) localStorage.removeItem('selectedProperty');
          bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
          showToast('Property deleted', 'success');
          loadProperties();
        } else { showToast(res.error || 'Error', 'error'); }
      }
    });
  });
});
</script>
</body>
</html>
