<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Properties — Rental Manager</title>
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>

<%- include('_sidebar', { activePage: 'properties' }) %>

<div class="main-wrapper" id="mainWrapper">
  <%- include('_topbar', { title: 'Properties' }) %>

  <main class="page-content">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <p class="text-muted mb-0" id="propSubtitle">Loading…</p>
      <a href="/add-property" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Add Property
      </a>
    </div>

    <div class="row g-4" id="propertyCards">
      <% for(let i = 0; i < 2; i++) { %>
      <div class="col-xl-6">
        <div class="panel loading-shimmer" style="min-height:220px;"></div>
      </div>
      <% } %>
    </div>

  </main>
</div>

<!-- Edit Property Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Property</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="editPropId">
        <div class="mb-3">
          <label class="form-label">Property Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="editPropName" placeholder="e.g. 12 Main Street">
        </div>
        <div class="mb-3">
          <label class="form-label">Address</label>
          <input type="text" class="form-control" id="editPropAddress" placeholder="Full address">
        </div>
        <div class="mb-0">
          <label class="form-label">Notes</label>
          <textarea class="form-control" id="editPropNotes" rows="2" placeholder="Any notes…"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" id="editSaveBtn">
          <i class="bi bi-save me-1"></i>Save Changes
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger"><i class="bi bi-trash me-2"></i>Delete Property</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="mb-1">Delete <strong id="deletePropName"></strong>?</p>
        <p class="text-muted small mb-0">All rooms, tenants and ledger records for this property will be permanently removed.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-danger" id="deleteConfirmBtn">
          <i class="bi bi-trash me-1"></i>Delete
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('_scripts') %>
<script>
let deletePropId = null;

function loadProperties() {
  $.getJSON('/api/properties', function(res) {
    if (!res.success) return;
    const data = res.data;
    $('#propSubtitle').text(data.length === 1 ? '1 property' : `${data.length} properties`);

    const container = $('#propertyCards');
    container.empty();

    if (data.length === 0) {
      container.html(`
        <div class="col-12 text-center py-5">
          <i class="bi bi-building display-4 text-muted"></i>
          <p class="text-muted mt-3 mb-4">No properties yet. Add your first one to get started.</p>
          <a href="/add-property" class="btn btn-primary"><i class="bi bi-plus-circle me-2"></i>Add Property</a>
        </div>`);
      return;
    }

    data.forEach(function(p) {
      const isRooming = p.type === 'rooming';
      const typeLabel = isRooming ? 'Rooming' : 'Whole Property';
      const typeBg    = isRooming ? 'badge-rooming' : 'badge-whole';
      const typeIcon  = isRooming ? 'bi-door-open' : 'bi-house-door';

      const occupancyText = isRooming
        ? `${p.active_tenants} / ${p.room_count} rooms occupied`
        : (p.active_tenants > 0 ? 'Occupied' : 'Vacant');

      const occupancyClass = p.active_tenants > 0 ? 'text-success' : 'text-muted';
      const pendingBadge   = p.pending_weeks > 0
        ? `<span class="badge bg-warning text-dark ms-2">${p.pending_weeks} pending</span>`
        : '';

      const viewHref = isRooming
        ? `/rooms?property=${p.id}`
        : `/property/${p.id}`;
      const viewLabel = isRooming ? 'View Rooms' : 'View Tenant';
      const viewIcon  = isRooming ? 'bi-door-open' : 'bi-person';

      container.append(`
        <div class="col-xl-6">
          <div class="property-card">
            <div class="property-card__header">
              <div class="property-card__icon">
                <i class="bi ${typeIcon}"></i>
              </div>
              <div class="property-card__info">
                <div class="property-card__name">${p.name}</div>
                <div class="property-card__address">${p.address || '<span class="text-muted fst-italic">No address</span>'}</div>
              </div>
              <div class="d-flex flex-column align-items-end gap-1">
                <span class="property-type-badge property-type-badge--${p.type}">${typeLabel}</span>
                ${pendingBadge}
              </div>
            </div>

            <div class="property-card__body">
              <div class="property-card__stats">
                <div class="stat-item">
                  <div class="stat-item__label">Occupancy</div>
                  <div class="stat-item__value ${occupancyClass}" style="font-size:14px">${occupancyText}</div>
                </div>
                <div class="stat-item">
                  <div class="stat-item__label">Total Received</div>
                  <div class="stat-item__value">${fmt(p.total_received)}</div>
                </div>
              </div>

              <div class="property-card__actions">
                <a href="${viewHref}" class="btn btn-sm btn-primary">
                  <i class="bi ${viewIcon} me-1"></i>${viewLabel}
                </a>
                <button class="btn btn-sm btn-outline-secondary" onclick="openEdit(${p.id}, '${escHtml(p.name)}', '${escHtml(p.address || '')}', '${escHtml(p.notes || '')}')">
                  <i class="bi bi-pencil me-1"></i>Edit
                </button>
                <button class="btn btn-sm btn-outline-danger ms-auto" onclick="openDelete(${p.id}, '${escHtml(p.name)}')">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      `);
    });
  });
}

function escHtml(str) {
  return String(str).replace(/'/g, "\\'").replace(/"/g, '&quot;');
}

function openEdit(id, name, address, notes) {
  $('#editPropId').val(id);
  $('#editPropName').val(name);
  $('#editPropAddress').val(address);
  $('#editPropNotes').val(notes);
  new bootstrap.Modal(document.getElementById('editModal')).show();
}

function openDelete(id, name) {
  deletePropId = id;
  $('#deletePropName').text(name);
  new bootstrap.Modal(document.getElementById('deleteModal')).show();
}

$(function() {
  loadProperties();

  $('#editSaveBtn').on('click', function() {
    const id   = $('#editPropId').val();
    const name = $('#editPropName').val().trim();
    if (!name) { showToast('Property name is required', 'error'); return; }

    $.ajax({
      url: `/api/properties/${id}`,
      method: 'PUT',
      contentType: 'application/json',
      data: JSON.stringify({
        name:    name,
        address: $('#editPropAddress').val().trim(),
        notes:   $('#editPropNotes').val().trim(),
      }),
      success: function(res) {
        if (res.success) {
          bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
          showToast('Property updated', 'success');
          loadProperties();
        } else {
          showToast(res.error || 'Error', 'error');
        }
      }
    });
  });

  $('#deleteConfirmBtn').on('click', function() {
    if (!deletePropId) return;
    $.ajax({
      url: `/api/properties/${deletePropId}`,
      method: 'DELETE',
      success: function(res) {
        if (res.success) {
          bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
          showToast('Property deleted', 'success');
          loadProperties();
        } else {
          showToast(res.error || 'Error', 'error');
        }
      }
    });
  });
});
</script>
</body>
</html>
