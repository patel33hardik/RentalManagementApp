    $('#expenseModalTitle').text('Add Expense');
    $('#editExpenseId').val('');
    $('#editExpDate').val(isoToday());
    $('#editExpCategory').val('Utilities');
    $('#editExpDesc').val('');
    $('#editExpAmount').val('');
    $('#editExpNotes').val('');
  }
  mExpense.show();
}

function saveExpense() {
  const id = $('#editExpenseId').val();
  const data = {
    date:        $('#editExpDate').val(),
    description: $('#editExpDesc').val().trim(),
    category:    $('#editExpCategory').val(),
    amount:      $('#editExpAmount').val(),
    notes:       $('#editExpNotes').val(),
  };
  if (!data.date || !data.description || !data.amount) { showToast('Date, description and amount are required', 'error'); return; }
