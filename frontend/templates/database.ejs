  const url    = id ? `/api/expenses/${id}` : '/api/expenses';
  $.ajax({ url, method, contentType: 'application/json', data: JSON.stringify(data),
    success: function(res) {
      if (res.success) { mExpense.hide(); showToast(id ? 'Expense updated' : 'Expense added', 'success'); loadExpenses(); }
      else showToast(res.error || 'Error', 'error');
    }
  });
}

function deleteExpenseRow(id) {
  confirmDelete('expense', function() {
    $.ajax({ url: `/api/expenses/${id}`, method: 'DELETE',
      success: function(res) {
        if (res.success) { showToast('Expense deleted', 'success'); loadExpenses(); }
      }
    });
  });
}

// ════════════════════════════════════════════════════════════════
// BACKUP — Location + Export
// ════════════════════════════════════════════════════════════════
function loadBackupSettings() {
  $.getJSON('/api/settings', function(res) {
    if (!res.success) return;
    const s = res.data;
    if (s.backup_path) {
      $('#backupPath').val(s.backup_path);
      $('#exportToPathBtn').prop('disabled', false);
    }
    if (s.last_backup && s.last_backup_file) {
      const d = new Date(s.last_backup);
      const label = d.toLocaleString('en-AU', { dateStyle: 'medium', timeStyle: 'short' });
      $('#lastBackupInfo').html(`Last export: <strong>${s.last_backup_file}</strong> at ${label}`);
    }
  });
}

$('#browseBtn').on('click', async function() {
  if (!window.electronAPI) { showToast('Folder picker only works inside the Electron app', 'error'); return; }
  const folder = await window.electronAPI.pickFolder();
  if (!folder) return;
  $('#backupPath').val(folder);
  $('#exportToPathBtn').prop('disabled', false);
  $.ajax({
    url: '/api/settings', method: 'POST', contentType: 'application/json',
    data: JSON.stringify({ backup_path: folder }),
  });
});

$('#exportToPathBtn').on('click', function() {
  const btn = $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Exporting…');
  $.ajax({
    url: '/api/db/export-to-path', method: 'POST',
    success: function(res) {
      btn.prop('disabled', false).html('<i class="bi bi-cloud-arrow-down me-2"></i>Export to Folder');
      if (res.success) {
        showToast(`Saved: ${res.file}`, 'success');
        loadBackupSettings();
      } else {
        showToast(res.error || 'Export failed', 'error');
      }
    },
    error: function(xhr) {
      btn.prop('disabled', false).html('<i class="bi bi-cloud-arrow-down me-2"></i>Export to Folder');
      const msg = xhr.responseJSON ? xhr.responseJSON.error : 'Export failed';
      showToast(msg, 'error');
    }
  });
});

// ════════════════════════════════════════════════════════════════
// BACKUP — Import
// ════════════════════════════════════════════════════════════════
$('#importFileInput').on('change', function() {
  $('#importBtn').prop('disabled', !this.files.length);
});

$('#importBtn').on('click', function() {
  const file = $('#importFileInput')[0].files[0];
  if (!file) return;
  if (!confirm('Replace ALL current data with this file? This cannot be undone.')) return;

  const btn = $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Importing…');
  fetch('/api/db/import', {
    method: 'POST',
    headers: { 'Content-Type': 'application/octet-stream' },
    body: file,
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      showToast('Database imported — reloading data…', 'success');
      $('#importFileInput').val('');
      btn.prop('disabled', true).html('<i class="bi bi-upload me-2"></i>Import &amp; Replace Database');
      loadRooms(); loadTenants(); loadLedger(); loadBondPayments(); loadExpenses(); loadTenantDropdowns();
    } else {
      showToast(res.error || 'Import failed', 'error');
      btn.prop('disabled', false).html('<i class="bi bi-upload me-2"></i>Import &amp; Replace Database');
    }
  })
  .catch(function() {
    showToast('Import failed — check the file and try again', 'error');
    btn.prop('disabled', false).html('<i class="bi bi-upload me-2"></i>Import &amp; Replace Database');
  });
});
</script>
</body>
</html>
