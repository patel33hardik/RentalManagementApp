<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Tenant — Rental Manager</title>
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/common/thirdparty/bootstrap/css/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>

<%- include('_sidebar', { activePage: 'rooms' }) %>

<div class="main-wrapper" id="mainWrapper">
  <%- include('_topbar', { title: 'Add / Edit Tenant' }) %>

  <main class="page-content">

    <div class="row justify-content-center">
      <div class="col-lg-7">

        <div class="panel">
          <div class="panel__header">
            <h2 class="panel__title" id="formTitle">
              <i class="bi bi-person-plus me-2"></i>New Tenant
            </h2>
            <a href="/rooms" class="btn btn-sm btn-outline-secondary" id="backBtn">
              <i class="bi bi-arrow-left me-1"></i>Back
            </a>
          </div>
          <div class="panel__body">

            <form id="tenantForm">
              <input type="hidden" id="tenantId">
              <input type="hidden" id="contextPropertyId">

              <div class="row g-3">

                <!-- People Registry multi-picker (optional) -->
                <div class="col-12" id="registryPickerGroup">
                  <label class="form-label">
                    <i class="bi bi-person-lines-fill me-1 text-muted"></i>Select People from Registry
                    <small class="text-muted ms-1">(optional — names will be joined in the field below)</small>
                  </label>
                  <div id="selectedChips" class="d-flex flex-wrap gap-1 mb-2" style="min-height:10px;"></div>
                  <div class="border rounded">
                    <div class="p-2 bg-light border-bottom">
                      <input type="text" class="form-control form-control-sm" id="profileSearch" placeholder="Search people…">
                    </div>
                    <div id="profileCheckList" style="max-height:130px;overflow-y:auto;" class="px-2 py-1">
                      <div class="text-muted small text-center py-2">Loading registry…</div>
                    </div>
                  </div>
                </div>

                <!-- Room selector: shown for rooming properties, hidden for whole-property -->
                <div class="col-md-6" id="roomSelectorGroup">
                  <label class="form-label">Room <span class="text-danger">*</span></label>
                  <select class="form-select" id="roomId" required>
                    <option value="">Loading rooms…</option>
                  </select>
                </div>

                <!-- Whole-property: show read-only property name instead of room picker -->
                <div class="col-md-6" id="wholePropGroup" style="display:none;">
                  <label class="form-label">Property</label>
                  <input type="text" class="form-control" id="wholePropName" readonly>
                </div>

                <div class="col-md-6">
                  <label class="form-label">Tenant Name <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="tenantName" placeholder="Full name" required>
                </div>

                <div class="col-md-6">
                  <label class="form-label">Weekly Rent ($) <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input type="number" class="form-control" id="weeklyRent" placeholder="0.00" step="0.01" min="0" required>
                  </div>
                </div>

                <div class="col-md-6">
                  <label class="form-label">Bond Amount ($)</label>
                  <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input type="number" class="form-control" id="bondAmount" placeholder="0.00" step="0.01" min="0">
                  </div>
                </div>

                <div class="col-md-6">
                  <label class="form-label">Move-in Date</label>
                  <input type="date" class="form-control" id="moveIn">
                </div>

                <div class="col-md-6">
                  <label class="form-label">Move-out Date</label>
                  <input type="date" class="form-control" id="moveOut">
                </div>

                <div class="col-md-6">
                  <label class="form-label">Status</label>
                  <select class="form-select" id="tenantStatus">
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                  </select>
                </div>

                <div class="col-12">
                  <label class="form-label">Notes</label>
                  <textarea class="form-control" id="notes" rows="2" placeholder="Any additional notes…"></textarea>
                </div>
              </div>

              <div class="alert alert-info mt-4 mb-0" id="formAlert">
                <i class="bi bi-info-circle me-2"></i>
                Adding a new tenant will automatically generate <strong>12 weeks</strong> of pending ledger rows.
                <span id="alertDisplace"> Any existing active tenant in the selected room will be marked as moved out.</span>
              </div>

              <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary flex-grow-1" id="submitBtn">
                  <i class="bi bi-person-check me-2"></i>Add Tenant
                </button>
                <a href="/rooms" class="btn btn-outline-secondary" id="cancelBtn">Cancel</a>
              </div>

            </form>

          </div>
        </div>

      </div>
    </div>

  </main>
</div>

<%- include('_scripts') %>
<script>
$(function() {
  const prop       = requireProp();
  if (!prop) return;

  // ── People Registry multi-picker ────────────────────────────────────────────
  let allProfiles   = [];   // all profiles returned from API
  let selectedIds   = {};   // { id: profile_object }

  function rebuildNameField() {
    const names = Object.values(selectedIds).map(p => p.name);
    if (names.length) $('#tenantName').val(names.join(', '));
  }

  function renderChips() {
    const container = $('#selectedChips');
    container.empty();
    Object.values(selectedIds).forEach(function(p) {
      container.append(
        `<span class="badge bg-primary d-flex align-items-center gap-1 px-2 py-1 fw-normal" style="font-size:.85rem;">
          ${escHtml(p.name)}
          <i class="bi bi-x-circle-fill ms-1 chip-remove" data-pid="${p.id}" style="cursor:pointer;"></i>
        </span>`
      );
    });
    rebuildNameField();
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderCheckList(filter) {
    const list = $('#profileCheckList');
    const q = (filter || '').toLowerCase();
    const visible = allProfiles.filter(p => !q || p.name.toLowerCase().includes(q) || (p.mobile||'').includes(q));
    if (!visible.length) {
      list.html('<div class="text-muted small text-center py-2">No people found</div>');
      return;
    }
    list.empty();
    visible.forEach(function(p) {
      const checked = selectedIds[p.id] ? 'checked' : '';
      const sub = [p.mobile, p.email, p.doc_type].filter(Boolean).join(' · ');
      list.append(`
        <div class="form-check py-1 border-bottom" style="margin:0;">
          <input class="form-check-input profile-cb" type="checkbox" id="pcb_${p.id}"
                 data-id="${p.id}" ${checked}>
          <label class="form-check-label w-100" for="pcb_${p.id}" style="cursor:pointer;">
            <span class="fw-semibold">${escHtml(p.name)}</span>
            ${sub ? `<span class="text-muted small ms-2">${escHtml(sub)}</span>` : ''}
          </label>
        </div>
      `);
    });
  }

  function loadRegistry(preSelectedIds) {
    const editId = new URLSearchParams(window.location.search).get('edit');
    let url = '/api/tenant-profiles?available=1';
    if (editId) url += `&editing_tenant=${editId}`;

    $.getJSON(url, function(res) {
      if (!res.success) return;
      allProfiles = res.data;

      // Pre-select profiles already linked (edit mode)
      if (preSelectedIds && preSelectedIds.length) {
        preSelectedIds.forEach(function(pid) {
          const p = allProfiles.find(x => x.id === pid);
          if (p) selectedIds[p.id] = p;
        });
        renderChips();
      }

      renderCheckList('');
    });
  }

  // Checkbox toggle
  $(document).on('change', '.profile-cb', function() {
    const pid = parseInt($(this).data('id'));
    const p   = allProfiles.find(x => x.id === pid);
    if (!p) return;
    if ($(this).is(':checked')) {
      selectedIds[pid] = p;
    } else {
      delete selectedIds[pid];
    }
    renderChips();
  });

  // Chip remove
  $(document).on('click', '.chip-remove', function(e) {
    e.stopPropagation();
    const pid = parseInt($(this).data('pid'));
    delete selectedIds[pid];
    $(`#pcb_${pid}`).prop('checked', false);
    renderChips();
  });

  // Search filter
  $('#profileSearch').on('input', function() {
    renderCheckList($(this).val());
  });

  const params     = new URLSearchParams(window.location.search);
  const preRoom    = params.get('room');
  // Use URL property param if provided, otherwise fall back to stored property
  const propParam  = params.get('property') || prop.id;
  const editId     = params.get('edit');

  const backHref = `/rooms?property=${propParam}`;
  $('#backBtn').attr('href', backHref);
  $('#cancelBtn').attr('href', backHref);
  $('#contextPropertyId').val(propParam);

  if (editId) {
    // Edit mode: load tenant first, then load all rooms so we can pre-select
    $('#formTitle').html('<i class="bi bi-pencil me-2"></i>Edit Tenant');
    $('#submitBtn').html('<i class="bi bi-save me-2"></i>Save Changes');
    $('#tenantId').val(editId);

    $.getJSON(`/api/tenants/${editId}`, function(res) {
      if (!res.success) return;
      const t = res.data;
      loadRooms(t.property_id, t.room_id, t.property_type);
      $('#tenantName').val(t.name);
      $('#weeklyRent').val(t.weekly_rent);
      $('#bondAmount').val(t.bond);
      $('#moveIn').val(t.move_in || '');
      $('#moveOut').val(t.move_out || '');
      $('#tenantStatus').val(t.status || 'Active');
      $('#notes').val(t.notes || '');
      updateAlert(t.status || 'Active');

      if (t.property_type === 'whole') {
        $('#backBtn').attr('href', `/property/${t.property_id}`);
        $('#cancelBtn').attr('href', `/property/${t.property_id}`);
      }
    });

    // Load linked profiles for pre-selection
    $.getJSON(`/api/tenant-profiles?linked_to=${editId}`, function(res) {
      const preIds = res.success ? res.data.map(p => p.id) : [];
      loadRegistry(preIds);
    });
  } else {
    // Add mode: load rooms filtered by property if provided
    loadRooms(propParam, preRoom, null);
    loadRegistry([]);
  }

  // Load rooms from API, optionally filtered by property
  function loadRooms(propertyId, preSelectRoomId, knownType) {
    const url = propertyId
      ? `/api/rooms?property_id=${propertyId}`
      : '/api/rooms';

    $.getJSON(url, function(res) {
      if (!res.success) return;
      const rooms = res.data;

      // Detect whole-property: single hidden room
      const isWhole = knownType === 'whole' ||
        (rooms.length === 1 && rooms[0].property_type === 'whole');

      if (isWhole && rooms.length === 1) {
        // Hide room dropdown, show property name label
        $('#roomSelectorGroup').hide();
        $('#wholePropGroup').show();
        $('#wholePropName').val(rooms[0].property_name || 'Whole Property');
        $('#roomId').val(rooms[0].id).removeAttr('required');
        // hidden field carries the value
        $('<input type="hidden" id="roomIdHidden">').val(rooms[0].id).appendTo('#tenantForm');
        return;
      }

      // Build options
      const select = $('#roomId');
      select.empty().append('<option value="">Select room…</option>');
      rooms.forEach(function(r) {
        const label = rooms.some(x => x.property_id !== r.property_id)
          ? `${r.property_name} — Room ${r.room_number}${r.description ? ' · ' + r.description : ''}`
          : `Room ${r.room_number}${r.description ? ' — ' + r.description : ''}`;
        select.append(`<option value="${r.id}">${label}</option>`);
      });

      if (preSelectRoomId) select.val(preSelectRoomId);
    });
  }

  // Use hidden field value for whole-property
  function getRoomId() {
    const hidden = $('#roomIdHidden');
    return hidden.length ? hidden.val() : $('#roomId').val();
  }

  $('#tenantStatus').on('change', function() {
    updateAlert($(this).val());
  });

  function updateAlert(status) {
    if (status === 'Inactive') {
      $('#alertDisplace').hide();
      $('#formAlert').removeClass('alert-info').addClass('alert-secondary');
    } else {
      $('#alertDisplace').show();
      $('#formAlert').removeClass('alert-secondary').addClass('alert-info');
    }
  }

  $('#tenantForm').on('submit', function(e) {
    e.preventDefault();
    const editId = $('#tenantId').val();
    const roomId = getRoomId();
    if (!roomId) { showToast('Please select a room', 'error'); return; }

    const data = {
      room_id:     roomId,
      name:        $('#tenantName').val().trim(),
      weekly_rent: $('#weeklyRent').val(),
      bond:        $('#bondAmount').val() || 0,
      move_in:     $('#moveIn').val() || null,
      move_out:    $('#moveOut').val() || null,
      status:      $('#tenantStatus').val(),
      notes:       $('#notes').val(),
      profile_ids: Object.keys(selectedIds).map(Number),
    };

    const propId = $('#contextPropertyId').val();

    if (editId) {
      $.ajax({
        url: `/api/tenants/${editId}`,
        method: 'PUT',
        contentType: 'application/json',
        data: JSON.stringify(data),
        success: function(res) {
          if (res.success) {
            showToast('Tenant updated successfully', 'success');
            const dest = propId ? `/rooms?property=${propId}` : '/rooms';
            setTimeout(() => window.location.href = dest, 1000);
          } else {
            showToast(res.error || 'Error updating tenant', 'error');
          }
        }
      });
    } else {
      $.ajax({
        url: '/api/tenants',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(data),
        success: function(res) {
          if (res.success) {
            showToast('Tenant added & ledger created!', 'success');
            setTimeout(() => window.location.href = `/tenant/${res.data.id}`, 1200);
          } else {
            showToast(res.error || 'Error adding tenant', 'error');
          }
        }
      });
    }
  });
});
</script>
</body>
</html>
